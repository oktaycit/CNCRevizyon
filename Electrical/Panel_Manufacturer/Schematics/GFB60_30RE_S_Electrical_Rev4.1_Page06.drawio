        <!-- Sensor List -->
        <mxCell id="sensorlist" value="SENSÖ LİSTESİ&#10;&#10;┌──────┬───────────┬─────────┬──────────┐&#10;│ Eksen│ Pozisyon  │ Model   │ PLC Adr  │&#10;├──────┼───────────┼─────────┼──────────┤&#10;│ X    │ +LIMIT    │ IS218MM │ %IX0.0   │&#10;│ X    │ -LIMIT    │ IS218MM │ %IX0.1   │&#10;│ X    │ HOME      │ IS218MM │ %IX0.2   │&#10;│ Y    │ +LIMIT    │ IS218MM │ %IX0.3   │&#10;│ Y    │ -LIMIT    │ IS218MM │ %IX0.4   │&#10;│ Y    │ HOME      │ IS218MM │ %IX0.5   │&#10;│ Z    │ +LIMIT    │ IS218MM │ %IX0.6   │&#10;│ Z    │ HOME      │ IS218AM │ %IX0.7   │&#10;│ ALT  │ +LIMIT    │ IS218MM │ %IX0.8   │&#10;│ ALT  │ HOME      │ IS218MM │ %IX0.9   │&#10;└──────┴───────────┴─────────┴──────────┘&#10;&#10;Yedek Parça:&#10;• Leuze IS 218 MM: 10 adet&#10;• Leuze IS 218 AM: 2 adet&#10;• M12 4-pin dişi: 20 adet" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=9;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1400" y="430" width="240" height="220" as="geometry"/>
        </mxCell>

