        <mxCell id="subtitle" value="Leuze IS 218 MM/AM sensör montajı, M12 konnektör pinout, kablo routing ve shield sonlandırma&#10;X/Y/Z/ALT eksenleri home ve limit sensör yerleşimi, R1-EC0902D bağlantıları" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=12;" vertex="1" parent="1">
