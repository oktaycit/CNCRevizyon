        <!-- Leuze IS 218 Sensor Symbol -->
        <mxCell id="sensor1" value="Leuze IS 218 MM&#10;M18 x 1 x 75mm&#10;Inductive Sensor&#10;&#10;Sn = 8mm (10mm max)&#10;10-30V DC&#10;PNP NO/NC&#10;IP67/IP68/IP69K&#10;&#10;┌──────────┐&#10;│  ● LED   │&#10;│  Leuze   │&#10;│  IS 218  │&#10;│  M18     │&#10;└────┬─────┘&#10;     │ M18&#10;     ▼" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=2;fillColor=#fff2cc;strokeColor=#d6b656;align=center;fontSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="80" y="150" width="160" height="200" as="geometry"/>
        </mxCell>

        <!-- M12 4-pin Connector Pinout -->
        <mxCell id="m12pinout" value="M12 4-PIN CONNECTOR PINOUT&#10;&#10;Sensör Tarafı (Erkek)&#10;&#10;      1 (+24V)&#10;    ┌───────┐&#10;  4 │       │ 2&#10;    │       │&#10;    └───────┘&#10;      3 (0V)&#10;&#10;Pin 1: +24V DC (Brown)&#10;Pin 2: OUTPUT PNP (White)&#10;Pin 3: 0V DC (Blue)&#10;Pin 4: NO/NC Select (Black)&#10;&#10;Kablo Tarafı (Dişi)&#10;┌───────────────────────┐&#10;│ 1: Brown  → +24V      │&#10;│ 2: White  → Sinyal    │&#10;│ 3: Blue   → 0V        │&#10;│ 4: Black  → NO/NC     │&#10;│ Shield → PE (360°)    │&#10;└───────────────────────┘" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=2;fillColor=#ffffff;strokeColor=#6c8ebf;align=left;verticalAlign=top;fontSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="280" y="150" width="220" height="280" as="geometry"/>
        </mxCell>

        <!-- X Axis Sensor Layout -->
        <mxCell id="xaxis" value="X EKSENİ SENSÖR YERLEŞİMİ (6000mm)&#10;&#10;┌─────────────────────────────────────────────────────────┐&#10;│                    X Ekseni (6000mm)                    │&#10;│                                                         │&#10;│  [X+LIMIT]                    [X-HOME]                  │&#10;│  IS218-MM                     IS218-MM                 │&#10;│     │                              │                    │&#10;│     ▼                              ▼                    │&#10;│  ◄─────────────────────────────────────────►            │&#10;│                    5800 mm                               │&#10;│                                                         │&#10;│  [X-LIMIT]                                              │&#10;│  IS218-MM                                               │&#10;│     │                                                   │&#10;│     ▼                                                   │&#10;└─────────────────────────────────────────────────────────┘&#10;&#10;Konumlar:&#10;• X+LIMIT: X = 5950 mm (sağ uç) → IX0.1&#10;• X-LIMIT: X = -50 mm (sol uç) → IX0.2&#10;• X-HOME: X = 0 mm (referans) → IX0.0&#10;&#10;Ayar Aralığı: ±5 mm (ileri-geri)&#10;Algılama Mesafesi: 8±2 mm" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="540" y="150" width="520" height="220" as="geometry"/>
        </mxCell>

        <!-- Y Axis Sensor Layout -->
        <mxCell id="yaxis" value="Y EKSENİ SENSÖR YERLEŞİMİ (3000mm)&#10;&#10;┌─────────────────────────────────────┐&#10;│          Y Ekseni (3000mm)          │&#10;│                                     │&#10;│  [Y+LIMIT]                          │&#10;│  IS218-MM                           │&#10;│     │                               │&#10;│     ▼                               │&#10;│  ◄───────────────────────►          │&#10;│            2900 mm                  │&#10;│                                     │&#10;│  [Y-HOME]        [Y-LIMIT]          │&#10;│  IS218-MM        IS218-MM           │&#10;│     │                │              │&#10;│     ▼                ▼              │&#10;└─────────────────────────────────────┘&#10;&#10;Konumlar:&#10;• Y+LIMIT: Y = 2950 mm (ön uç) → IX0.3&#10;• Y-LIMIT: Y = -50 mm (arka uç) → IX0.4&#10;• Y-HOME: Y = 0 mm (referans) → IX0.5&#10;&#10;Montaj: L-şekilli alüminyum braket (6mm)" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="540" y="390" width="420" height="200" as="geometry"/>
        </mxCell>

        <!-- Z Axis Sensor Layout -->
        <mxCell id="zaxis" value="Z EKSENİ SENSÖR YERLEŞİMİ&#10;&#10;        ┌─────────────┐&#10;        │ Z Motor     │&#10;        │ (Frenli)    │&#10;        └──────┬──────┘&#10;               │&#10;        ┌──────▼──────┐&#10;        │ Z+LIMIT     │&#10;        │ IS218-MM    │&#10;        │ (Yukarı)    │&#10;        └──────┬──────┘&#10;               │&#10;        ═══════════════  Z = +100 mm&#10;               │&#10;        ┌──────▼──────┐&#10;        │ Z-HOME      │&#10;        │ IS218-AM    │&#10;        │ (Referans)  │&#10;        └──────┬──────┘&#10;               │&#10;        ═══════════════  Z = 0 mm (home)&#10;               │&#10;        ┌──────▼──────┐&#10;        │ Kesim Kafası│&#10;        └─────────────┘&#10;&#10;Z+LIMIT → IX2.1&#10;Z-HOME → IX2.0&#10;Braket: Paslanmaz çelik (4mm)" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="540" y="610" width="280" height="280" as="geometry"/>
        </mxCell>

        <!-- Mounting Bracket Detail -->
        <mxCell id="bracket" value="MONTAJ BRAKETİ DETAYI (X/Y Limit)&#10;&#10;Malzeme: Alüminyum 6061-T6 (6mm)&#10;Yüzey: Anodize (doğal)&#10;&#10;                    ┌────────────────────┐&#10;                    │   Sensör (M18)     │&#10;                    │   ┌──────────┐     │&#10;                    │   │  Leuze   │     │&#10;                    │   │  IS 218  │     │&#10;                    │   └──────────┘     │&#10;                    └─────────┬──────────┘&#10;                              │ M18 x 1&#10;        ┌─────────────────────┴─────────────────────┐&#10;        │     Ayar Vidaları (M5 x 10)               │&#10;        │    ┌───┐              ┌───┐              │&#10;        │    │ M5│              │ M5│              │&#10;        │    └───┘              └───┘              │&#10;        ├──────┴──────────────────┴────────────────┤&#10;        │                                         │&#10;        │         L-Şekilli Braket                │&#10;        │         60x60x6 mm                      │&#10;        │    ┌───────┐                            │&#10;        │    │ M6    │  (T-slot bağlantı)        │&#10;        │    └───────┘                            │&#10;        └─────────────────────────────────────────┘&#10;&#10;Ayar Aralığı: ±5 mm&#10;Montaj: M6 T-slot cıvata" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=9;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="840" y="390" width="380" height="240" as="geometry"/>
        </mxCell>

        <!-- Cable Specifications -->
        <mxCell id="cablespec" value="KABLO ÖZELLİKLERİ&#10;&#10;┌───────────────────────────────────────┐&#10;│ Tip: Shielded Sensor Cable            │&#10;│ İletken: 4 x 0.34 mm²                 │&#10;│ Dış Çap: 6.0 mm                       │&#10;│ Renk: Brown, White, Blue, Black       │&#10;│ Koruma: IP67, Yağa Dayanıklı          │&#10;│ Sıcaklık: -40°C ... +90°C             │&#10;│ Shield: Al/Mylar foil + drain wire    │&#10;│ Dış Kılıf: PUR (mor)                  │&#10;└───────────────────────────────────────┘&#10;&#10;Kablo Kanalı Routing:&#10;• Minimum bending radius: 6x cable diameter&#10;• Ayrı slot: Power ve signal kabloları&#10;• Doluluk oranı: max %50&#10;&#10;Drag Chain Routing:&#10;• Chainfill rating: Required&#10;• Bending radius: 7.5x cable diameter&#10;• Strain relief: Both ends&#10;• Max acceleration: 50 m/s²" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="380" width="200" height="240" as="geometry"/>
        </mxCell>

        <!-- Shield Termination -->
        <mxCell id="shield" value="SHIELD SONLANDIRMA&#10;&#10;┌──────────────────────────────────────────┐&#10;│ 360° Clamp ile PE Bar Bağlantısı         │&#10;└──────────────────────────────────────────┘&#10;&#10;Sensör Kablosu:&#10;┌──────────────────────────────┐&#10;│  Shield (Al/Mylar + Drain)   │&#10;│  ┌────┬────┬────┬────┐      │&#10;│  │ 1  │ 2  │ 3  │ 4  │      │&#10;│  └────┴────┴────┴────┘      │&#10;└──────────────────────────────┘&#10;         │&#10;         ▼&#10;┌─────────────────────────┐&#10;│  360° Shield Clamp      │&#10;│  (Weidmüller KLU 2.5)   │&#10;└───────────┬─────────────┘&#10;            │&#10;            ▼&#10;┌─────────────────────────┐&#10;│  PE Bar (X2.8)          │&#10;│  M4 terminal            │&#10;│  ┌───┬───┬───┬───┐      │&#10;│  │ • │ • │ • │ • │ ...  │&#10;│  └───────────────────┘  │&#10;└─────────────────────────┘&#10;&#10;Topraklama Direnci: &lt; 100Ω&#10;Kablo: 2.5mm² yeşil/sarı" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=9;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="80" y="640" width="220" height="260" as="geometry"/>
        </mxCell>

        <!-- R1-EC0902D Input Module Connections -->
        <mxCell id="r1ec" value="R1-EC0902D GİRİŞ MODÜLÜ BAĞLANTILARI&#10;&#10;Modül #1 - Terminal Block 1 (X/Y Ekseni)&#10;┌─────────────────────────────────────────┐&#10;│ Terminal │ Sinyal    │ PLC Adresi │ Pin │&#10;├──────────┼───────────┼────────────┼─────┤&#10;│    1     │ X+LIMIT   │ %IX0.0     │  2  │&#10;│    2     │ X-LIMIT   │ %IX0.1     │  2  │&#10;│    3     │ X-HOME    │ %IX0.2     │  2  │&#10;│    4     │ Y+LIMIT   │ %IX0.3     │  2  │&#10;│    5     │ Y-LIMIT   │ %IX0.4     │  2  │&#10;│    6     │ Y-HOME    │ %IX0.5     │  2  │&#10;│    7     │ Z+LIMIT   │ %IX0.6     │  2  │&#10;│    8     │ Z-HOME    │ %IX0.7     │  2  │&#10;│    9     │ ALT+LIMIT │ %IX0.8     │  2  │&#10;│   10     │ ALT-HOME  │ %IX0.9     │  2  │&#10;│   COM    │ 0V        │ GND        │  3  │&#10;└─────────────────────────────────────────┘&#10;&#10;Besleme: +24V (Terminal 1) → Tüm sensörler&#10;Ortak 0V: Tüm Blue kablolar COM'a&#10;Sinyal: White kablolar → PLC Input" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=2;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;fontSize=9;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1100" y="150" width="280" height="260" as="geometry"/>
        </mxCell>

        <!-- NO/NC Selection Table -->
        <mxCell id="nonc" value="NO/NC SEÇİMİ&#10;&#10;┌──────────────────────────────────────┐&#10;│ Uygulama   │ Ayar │ Açıklama        │&#10;├────────────┼──────┼─────────────────┤&#10;│ Limit SW   │  NC  │ Güvenlik        │&#10;│ Home SW    │  NO  │ Referans tespit │&#10;│ E-Stop     │  NC  │ Güvenlik        │&#10;│ Glass Det. │  NO  │ Var/Yok         │&#10;└──────────────────────────────────────┘&#10;&#10;Limit Switch (NC):&#10;• Normalde kapalı kontak&#10;• Kablo kopukluğunda güvenli&#10;• Algılama → Kontak açılır → PLC LOW&#10;&#10;Home Switch (NO):&#10;• Normalde açık kontak&#10;• Referans kenar tespiti&#10;• Algılama → Kontak kapanır → PLC HIGH&#10;&#10;Pin 4 Bağlantısı:&#10;• NC için: Pin 4 → +24V&#10;• NO için: Pin 4 → 0V" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1100" y="430" width="280" height="220" as="geometry"/>
        </mxCell>

        <!-- Cable Routing Notes -->
        <mxCell id="routing" value="KABLO KANALI VE DRAG CHAIN ROUTING&#10;&#10;┌─────────────────────────────────────────┐&#10;│ Kablo Kanalı Düzeni                     │&#10;├─────────────────────────────────────────┤&#10;│ ┌─────┬─────┬─────┬─────┐               │&#10;│ │Power│Sens │Enc  │Shld │ ← Bölmeler   │&#10;│ └─────┴─────┴─────┴─────┘               │&#10;│                                         │&#10;│ • Sensor kabloları ayrı slot           │&#10;│ • Shield drain wire PE bar'a           │&#10;│ • Cable ties: 100mm aralıklı           │&#10;│ • Label: Her iki uçta                 │&#10;└─────────────────────────────────────────┘&#10;&#10;┌─────────────────────────────────────────┐&#10;│ Drag Chain Kuralları                    │&#10;├─────────────────────────────────────────┤&#10;│ • Chainfill rated cable kullan         │&#10;│ • Min bending radius: 7.5x Ø           │&#10;│ • Strain relief: Her iki uçta          │&#10;│ • Mekanik stres yok                    │&#10;│ • Hareket yönüne paralel               │&#10;└─────────────────────────────────────────┘&#10;&#10;Etiketleme:&#10;• X+LIMIT: XSL-01 → R1-EC:X20.1&#10;• Y-HOME: YSL-03 → R1-EC:X20.6" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1100" y="670" width="280" height="240" as="geometry"/>
        </mxCell>

        <!-- Test Points and LED Status -->
        <mxCell id="testpoints" value="TEST NOKTALARI VE LED DURUM TABLOSU&#10;&#10;┌──────────────────────────────────────────┐&#10;│ Sensör LED Durumları                     │&#10;├──────────────────────────────────────────┤&#10;│ LED    │ Durum      │ Anlamı            │&#10;├────────┼────────────┼───────────────────┤&#10;│ PWR    │ Yeşil      │ 24V OK            │&#10;│ OUT    │ Yeşil      │ Algılama aktif    │&#10;│ OUT    │ Kapalı     │ Algılama yok      │&#10;└──────────────────────────────────────────┘&#10;&#10;┌──────────────────────────────────────────┐&#10;│ Test Noktaları                           │&#10;├──────────────────────────────────────────┤&#10;│ TP1: +24V_SENS (X2.3) → Multimeter      │&#10;│ TP2: 0V_SENS (X2.7) → Multimeter        │&#10;│ TP3: X+LIMIT_SIG → Oscilloscope         │&#10;│ TP4: Y-HOME_SIG → Oscilloscope          │&#10;└──────────────────────────────────────────┘&#10;&#10;Test Prosedürü:&#10;1. 24V DC ölç (23.5-24.5V)&#10;2. Metal parça yaklaştır (8mm)&#10;3. OUT LED yanmalı&#10;4. PLC girişini kontrol et (%IXx.x)&#10;5. Algılama mesafesini ölç" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="920" width="320" height="200" as="geometry"/>
        </mxCell>

        <!-- Wiring Diagram Detail -->
        <mxCell id="wiring" value="TAM KABLOLAMA ŞEMASI&#10;&#10;Sensör Tarafı (M12)          Pano Tarafı (R1-EC0902D)&#10;─────────────────          ─────────────────────────&#10;&#10;    Brown ────────────────────────► +24V (X2.3)&#10;    White ────────────────────────► Sinyal (Terminal 1-10)&#10;    Blue  ────────────────────────► 0V (X2.7)&#10;    Black ────────────────────────► NO/NC Select&#10;&#10;M12 Konnektör (Sensör)         Terminal Bloğu (Pano)&#10;    ┌───────┐                    ┌───────┐&#10;    │  ● 1  │ Brown (+24V)       │  ● 1  │ +24V (X2.3)&#10;    │  ● 2  │ White (Sinyal)     │  ● 2  │ Sinyal → PLC Input&#10;    │  ● 3  │ Blue (0V)          │  ● 3  │ 0V (X2.7)&#10;    │  ● 4  │ Black (NO/NC)      │  ● 4  │ +24V/0V (seçim)&#10;    └───────┘                    └───────┘&#10;         │                            │&#10;         ▼                            ▼&#10;    Shield → PE Bar            COM → 0V BUS" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=9;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="420" y="920" width="520" height="200" as="geometry"/>
        </mxCell>

        <!-- Cross References -->
        <mxCell id="crossref" value="SAYFA REFERANSLARI&#10;&#10;Page 01 → +24V_SENS (X2.3)&#10;Page 01 → 0V_SENS (X2.7)&#10;Page 01 → PE Bar (X2.8)&#10;Page 02 → Safety inputs&#10;Page 03 → NC300 I/O&#10;Page 05 → R1-EC modüller&#10;Page 07 → PLC I/O dağıtımı" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1400" y="920" width="200" height="140" as="geometry"/>
