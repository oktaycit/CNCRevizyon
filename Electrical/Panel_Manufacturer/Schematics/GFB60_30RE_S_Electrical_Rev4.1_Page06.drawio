        <mxCell id="pageTag6" value="PAGE 06 / SENSORS&#10;Rev 4.1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#2b5a8a;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1510" y="30" width="170" height="32" as="geometry"/>
