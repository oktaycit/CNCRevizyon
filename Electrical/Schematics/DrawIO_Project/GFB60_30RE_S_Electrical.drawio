        <mxCell id="terminals" value="Terminal Gruplari&#10;X1 AC INPUT&#10;X2 24V DISTRIBUTION&#10;X10 SAFETY INPUTS&#10;X11 STO OUTPUTS&#10;X20 DI TERMINAL&#10;X30 NC300 POWER&#10;X31 NC300 FIELD I/O" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1-6"><mxGeometry x="60" y="160" width="240" height="250" as="geometry"/></mxCell>
