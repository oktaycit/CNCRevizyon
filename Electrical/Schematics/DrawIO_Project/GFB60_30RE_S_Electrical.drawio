        <mxCell id="colors" value="Renk Kodu&#10;AC: BN / BK / GY / BU / GN-YE&#10;DC: RD +24V / BK 0V&#10;Safety: YE&#10;Sensor: Mavi tabanli saha kablosu" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1-6"><mxGeometry x="720" y="420" width="240" height="140" as="geometry"/></mxCell>
