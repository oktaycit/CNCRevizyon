        <!-- D-Sub 50-pin Critical Pins -->
        <mxCell id="dsub50_pins" value="KRİTİK PIN ASSIGNMENTS&#10;&#10;┌─────┬────────────┬──────────────────────────┐&#10;│ Pin │ Sinyal     │ Açıklama                 │&#10;├─────┼────────────┼──────────────────────────┤&#10;│  6  │ S-ON       │ Servo ON (aktif low)     │&#10;│  7  │ /S-ON      │ Servo ON complement      │&#10;│  9  │ +24V       │ Kontrol gücü             │&#10;│ 11  │ DI_0       │ P-OT (overtravel)        │&#10;│ 12  │ DI_1       │ N-OT (overtravel)        │&#10;│ 13  │ DI_2       │ TLL (torque limit)       │&#10;│ 14  │ DI_3       │ ARST (alarm reset)       │&#10;│ 21  │ V_REF+     │ Analog command +         │&#10;│ 22  │ V_REF-     │ Analog command -         │&#10;│ 23  │ AGND       │ Analog ground            │&#10;│ 29  │ STO1       │ Safe Torque Off CH1      │&#10;│ 30  │ STO2       │ Safe Torque Off CH2      │&#10;│ 31  │ PULSE+     │ Pulse command +          │&#10;│ 32  │ PULSE-     │ Pulse command -          │&#10;│ 33  │ SIGN+      │ Direction command +      │&#10;│ 34  │ SIGN-      │ Direction command -      │&#10;│ 35  │ FG         │ Frame ground             │&#10;│ 36  │ DO_1       │ ALM (alarm output)       │&#10;│ 43  │ STO_COM    │ STO return (0V)          │&#10;│ 44  │ COM+       │ 24V return               │&#10;└─────┴────────────┴──────────────────────────┘" style="text;html=0;strokeColor=#9673a6;fillColor=#ffffff;align=left;verticalAlign=top;fontSize=8;fontFamily=Courier New;" vertex="1" parent="1">
