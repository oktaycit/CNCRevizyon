        <!-- Servo Motor Cable Assembly -->
        <mxCell id="servo_cable_asm" value="SERVO MOTOR CABLE ASSEMBLY&#10;&#10;┌─────────────────────────────────────────────┐&#10;│  Drive Side                  Motor Side     │&#10;│  ┌──────────┐              ┌──────────┐     │&#10;│  │ Terminal │              │ Terminal │     │&#10;│  │ Block P2 │              │ Box      │     │&#10;│  │ R/S/T/PE │              │ U/V/W/PE │     │&#10;│  └────┬─────┘              └─────┬────┘     │&#10;│       │                          │          │&#10;│       └──────────┬───────────────┘          │&#10;│                  │                          │&#10;│        4x4.0mm² + Shield                    │&#10;│        Length: 5-20m                        │&#10;│        Continuous flex rated                │&#10;└─────────────────────────────────────────────┘&#10;&#10;Kablo yapısı:&#10;┌─────────────────────────────────┐&#10;│  ┌───────────────────────────┐  │&#10;│  │ PUR jacket (orange)       │  │&#10;│  │  ┌─────────────────────┐  │  │&#10;│  │  │ Tinned copper braid │  │  │&#10;│  │  │  ═══════════════    │  │  │&#10;│  │  │  ││││││││││││││││  │  │  │&#10;│  │  │  │  ┌───────────┐  │  │  │&#10;│  │  │  │  │ 4x4.0mm²  │  │  │  │&#10;│  │  │  │  │ twisted   │  │  │  │&#10;│  │  │  │  └───────────┘  │  │  │&#10;│  │  │  │                 │  │  │&#10;│  │  │  └─────────────────┘  │  │&#10;│  │  └─────────────────────┘  │  │&#10;│  └───────────────────────────┘  │&#10;└─────────────────────────────────┘&#10;&#10;Çap: ~12mm&#10;Bending radius: 10x cable diameter&#10;Cycle rating: >5 million" style="text;html=0;strokeColor=#d79b00;fillColor=#ffe6cc;align=left;verticalAlign=top;fontSize=8;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1600" y="1040" width="320" height="260" as="geometry"/>
        </mxCell>

        <!-- Encoder Cable Assembly -->
        <mxCell id="encoder_cable_asm" value="ENCODER CABLE ASSEMBLY&#10;&#10;┌─────────────────────────────────────────────┐&#10;│  Drive Side                  Motor Side     │&#10;│  ┌──────────┐              ┌──────────┐     │&#10;│  │ Hirose   │              │ Hirose   │     │&#10;│  │ 7P-6S    │              │ 7R-6S    │     │&#10;│  │ (plug)   │              │(recept.) │     │&#10;│  └────┬─────┘              └─────┬────┘     │&#10;│       │                          │          │&#10;│       └──────────┬───────────────┘          │&#10;│                  │                          │&#10;│        6x0.14mm² + Shield                   │&#10;│        Length: 5-20m                        │&#10;└─────────────────────────────────────────────┘&#10;&#10;Kablo yapısı:&#10;┌─────────────────────────────────┐&#10;│  ┌───────────────────────────┐  │&#10;│  │ PUR jacket (gray)         │  │&#10;│  │  ┌─────────────────────┐  │  │&#10;│  │  │ Tinned copper braid │  │  │&#10;│  │  │  ┌───────────────┐  │  │  │&#10;│  │  │  │ 6x twisted    │  │  │  │&#10;│  │  │  │ pairs         │  │  │  │&#10;│  │  │  │ (individually │  │  │  │&#10;│  │  │  │  shielded)    │  │  │  │&#10;│  │  │  └───────────────┘  │  │  │&#10;│  │  │                     │  │  │&#10;│  │  └─────────────────────┘  │  │&#10;│  └───────────────────────────┘  │&#10;└─────────────────────────────────┘&#10;&#10;Çap: ~5.5mm&#10;Impedans: 100Ω ±15%&#10;Capacitance: &lt;60pF/m" style="text;html=0;strokeColor=#d79b00;fillColor=#fff2cc;align=left;verticalAlign=top;fontSize=8;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1600" y="1320" width="320" height="260" as="geometry"/>
        </mxCell>

        <!-- EtherCAT Cable Assembly -->
        <mxCell id="ethercat_cable_asm" value="ETHERCAT CABLE ASSEMBLY&#10;&#10;┌─────────────────────────────────────────────┐&#10;│  NC300/Drive Side        Drive/Module Side  │&#10;│  ┌──────────┐              ┌──────────┐     │&#10;│  │ RJ45     │              │ RJ45     │     │&#10;│  │ (male)   │              │ (male)   │     │&#10;│  │ industrial             │ industrial     │&#10;│  └────┬─────┘              └─────┬────┘     │&#10;│       │                          │          │&#10;│       └──────────┬───────────────┘          │&#10;│                  │                          │&#10;│        CAT6 SF/UTP                          │&#10;│        Length: 1-100m                       │&#10;└─────────────────────────────────────────────┘&#10;&#10;Kablo yapısı:&#10;┌─────────────────────────────────┐&#10;│  ┌───────────────────────────┐  │&#10;│  │ PUR jacket (green)        │  │&#10;│  │  ┌─────────────────────┐  │  │&#10;│  │  │ Tinned copper braid │  │  │&#10;│  │  │  ┌───────────────┐  │  │  │&#10;│  │  │  │ Aluminum foil │  │  │  │&#10;│  │  │  │  ┌─────────┐  │  │  │&#10;│  │  │  │  │ 4x2xAWG │  │  │  │&#10;│  │  │  │  │ 26      │  │  │  │&#10;│  │  │  │  └─────────┘  │  │  │&#10;│  │  │  │               │  │  │&#10;│  │  │  └───────────────┘  │  │  │&#10;│  │  │                     │  │  │&#10;│  │  └─────────────────────┘  │  │&#10;│  └───────────────────────────┘  │&#10;└─────────────────────────────────┘&#10;&#10;Çap: 6.0-6.5mm&#10;Bending radius: 8x cable diameter&#10;Transmission: 100 Mbps&#10;Cycle time: 1ms" style="text;html=0;strokeColor=#82b366;fillColor=#d5e8d4;align=left;verticalAlign=top;fontSize=8;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1940" y="1040" width="320" height="260" as="geometry"/>
