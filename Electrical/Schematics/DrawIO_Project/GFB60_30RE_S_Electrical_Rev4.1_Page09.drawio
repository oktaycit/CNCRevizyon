        <!-- 360° Clamp Method -->
        <mxCell id="shield_360" value="360° CLAMP (ÖNERİLEN)&#10;&#10;┌─────────────────────────────────┐&#10;│  Cable jacket stripped          │&#10;│  ┌───────────────────────────┐  │&#10;│  │  ┌─────────────────────┐  │  │&#10;│  │  │ Foil shield         │  │  │&#10;│  │  │  ═══════════════    │  │  │&#10;│  │  │  ││││││││││││││││  │  │  │&#10;│  │  │  └─────────────────┘  │  │&#10;│  │  │  ╔════════════════╗   │  │&#10;│  │  │  ║ 360° Clamp    ║   │  │&#10;│  │  │  ║ (metal ring)  ║   │  │&#10;│  │  │  ╚════════════════╝   │  │&#10;│  │  └─────────────────────┘  │  │&#10;│  └───────────────────────────┘  │&#10;│         │                       │&#10;│         ▼                       │&#10;│  ┌─────────────┐                │&#10;│  │ Connector   │                │&#10;│  │ backshell   │                │&#10;│  └─────────────┘                │&#10;└─────────────────────────────────┘&#10;&#10;Avantajlar:&#10;- 360° EMI koruması&#10;- Düşük transfer impedansı&#10;- Yüksek frekans koruması&#10;- Mekanik dayanıklılık&#10;&#10;Kullanım: EtherCAT, Encoder, Servo" style="text;html=0;strokeColor=#0a7a0a;fillColor=#e8f5e9;align=left;verticalAlign=top;fontSize=8;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1600" y="190" width="280" height="240" as="geometry"/>
        </mxCell>

        <!-- Pigtail Method (FORBIDDEN) -->
        <mxCell id="shield_pigtail" value="PIGTAIL (YASAK!) ❌&#10;&#10;┌─────────────────────────────────┐&#10;│  ┌───────────────────────────┐  │&#10;│  │  ┌─────────────────────┐  │  │&#10;│  │  │  ═══════════════    │  │  │&#10;│  │  │  ││││││││││││││││  │  │  │&#10;│  │  │  └─────────────────┘  │  │&#10;│  │  │         │             │  │&#10;│  │  │         │ ❌          │  │&#10;│  │  │         │             │  │&#10;│  │  │      ┌──┴──┐          │  │&#10;│  │  │      │Wire │          │  │&#10;│  │  │      └──┬──┘          │  │&#10;│  │  │         │             │  │&#10;│  │  │         ▼             │  │&#10;│  │  │      Terminal         │  │&#10;│  │  └─────────────────────┘  │  │&#10;│  └───────────────────────────┘  │&#10;└─────────────────────────────────┘&#10;&#10;❌ NEDEN YASAK:&#10;- Yüksek empedans (&gt;100mΩ)&#10;- Antenn etkisi (RFI)&#10;- Düşük frekans koruması&#10;- EMC uyumsuzluğu&#10;- Endüstriyel standartlara&#10;  aykırı (EN 61800-3)&#10;&#10;ASLA kullanmayın!" style="text;html=0;strokeColor=#cc0000;fillColor=#f8cecc;align=left;verticalAlign=top;fontSize=8;fontFamily=Courier New;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1600" y="450" width="280" height="240" as="geometry"/>
        </mxCell>

        <!-- Ground Lug Method -->
        <mxCell id="shield_gndlug" value="GROUND LUG (GÜÇ KABLOLARI)&#10;&#10;┌─────────────────────────────────┐&#10;│  ┌───────────────────────────┐  │&#10;│  │  ┌─────────────────────┐  │  │&#10;│  │  │  ═══════════════    │  │  │&#10;│  │  │  ││││││││││││││││  │  │  │&#10;│  │  │  └─────────────────┘  │  │&#10;│  │  │         │             │  │&#10;│  │  │         ▼             │  │&#10;│  │  │  ┌─────────────┐      │  │&#10;│  │  │  │ Ground Lug  │      │  │&#10;│  │  │  │ (ring term) │      │  │&#10;│  │  │  └──────┬──────┘      │  │&#10;│  │  │         │             │  │&#10;│  │  │         ▼             │  │&#10;│  │  │  ┌─────────────┐      │  │&#10;│  │  │  │ PE Bara     │      │  │&#10;│  │  │  │ (M4/M5/M6)  │      │  │&#10;│  │  │  └─────────────┘      │  │&#10;│  │  └─────────────────────┘  │  │&#10;│  └───────────────────────────┘  │&#10;└─────────────────────────────────┘&#10;&#10;Kullanım: AC güç kabloları&#10;          Motor güç kabloları&#10;          (&gt;4mm² kesit)&#10;&#10;Lug boyutu:&#10;- 4mm²: M4 ring terminal&#10;- 6mm²: M5 ring terminal&#10;- 10mm²: M6 ring terminal&#10;&#10;Tork değerleri:&#10;- M4: 1.2-1.5 Nm&#10;- M5: 2.0-2.5 Nm&#10;- M6: 3.0-3.5 Nm" style="text;html=0;strokeColor=#0a7a0a;fillColor=#e8f5e9;align=left;verticalAlign=top;fontSize=8;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1600" y="710" width="280" height="240" as="geometry"/>
        </mxCell>

