        </mxCell>

        <!-- CN2 EtherCAT IN (Loop) -->
        <mxCell id="cn2" value="CN2&#10;EtherCAT IN&#10;RJ45 (Loop Back)&#10;&#10;1 TX+ ← CNC Axis CN6:1&#10;2 TX- ← CNC Axis CN6:2&#10;3 RX+ → CNC Axis CN6:3&#10;6 RX- → CNC Axis CN6:6&#10;&#10;Ring topology&#10;Redundancy" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=2;fillColor=#d5e8d4;strokeColor=#82b366;align=left;fontSize=10;" vertex="1" parent="1">
