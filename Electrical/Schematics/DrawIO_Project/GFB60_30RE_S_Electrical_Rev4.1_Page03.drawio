        <!-- EtherCAT Topology Diagram -->
        <mxCell id="ecattopo" value="ETHERCAT TOPOLOGY&#10;&#10;        ┌─────────────┐&#10;        │   NC300     │&#10;        │  (Master)   │&#10;        └──────┬──────┘&#10;               │ CN1 (OUT)&#10;               ▼&#10;        ┌─────────────┐&#10;   ┌───►│  X Axis     │───┐&#10;   │    │  (Node 1)   │   │&#10;   │    └─────────────┘   │&#10;   │                      │&#10;   │    ┌─────────────┐   │&#10;   │    │  Y Axis     │   │&#10;   └───►│  (Node 2)   │◄──┘&#10;        └─────────────┘&#10;               │&#10;               ▼&#10;        ┌─────────────┐&#10;        │  ALT Axis   │&#10;        │  (Node 3)   │&#10;        └─────────────┘&#10;               │&#10;               ▼&#10;        ┌─────────────┐&#10;        │   Z Axis    │&#10;        │  (Node 4)   │&#10;        └─────────────┘&#10;               │&#10;               ▼&#10;        ┌─────────────┐&#10;        │  CNC Axis   │&#10;        │  (Node 5)   │&#10;        └──────┬──────┘&#10;               │ CN6 (OUT)&#10;               ▼&#10;        ┌─────────────┐&#10;        │   R1-EC     │&#10;        │  (Node 6)   │&#10;        └──────┬──────┘&#10;               │&#10;               ▼&#10;        ┌─────────────┐&#10;        │   NC300     │&#10;        │  CN2 (IN)   │&#10;        └─────────────┘&#10;&#10;Cycle Time: 1ms&#10;Address: Auto-increment" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=9;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1000" y="150" width="280" height="520" as="geometry"/>
        </mxCell>

        <!-- Node Address Table -->
