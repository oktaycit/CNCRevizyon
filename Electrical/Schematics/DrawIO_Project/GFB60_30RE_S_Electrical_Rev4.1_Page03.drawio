        <!-- NC300 Power Input -->
        <mxCell id="u1pwr" value="NC300 POWER&#10;+24V (Page 01 X2:1) → F2 (4A)&#10;0V (Page 01 X2:6) → 0V BUS&#10;FG → PE Bar (2.5mm²)&#10;&#10;Power Consumption: 2A max&#10;Sigorta: F2 4A fast-blow" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;align=left;verticalAlign=top;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="580" width="280" height="120" as="geometry"/>
        </mxCell>

        <!-- CN1 EtherCAT OUT -->
        <mxCell id="cn1" value="CN1&#10;EtherCAT OUT&#10;RJ45&#10;&#10;1 TX+ → X Axis CN3:1&#10;2 TX- → X Axis CN3:2&#10;3 RX+ ← X Axis CN3:3&#10;6 RX- ← X Axis CN3:6&#10;&#10;CAT6 Shielded&#10;Max 100m" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=2;fillColor=#d5e8d4;strokeColor=#82b366;align=left;fontSize=10;" vertex="1" parent="1">
