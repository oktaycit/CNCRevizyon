          <mxGeometry x="450" y="470" width="180" height="140" as="geometry"/>
        </mxCell>

        <!-- CN5 50-pin I/O -->
        <mxCell id="cn5" value="CN5&#10;50-pin D-Sub I/O&#10;&#10;DI_0: SERVO_READY&#10;DI_1: CYCLE_START&#10;DI_2: CYCLE_STOP&#10;DI_3: HOME_CMD&#10;DI_4: E-STOP_FB (Page 02)&#10;&#10;DO_0: SYSTEM_READY&#10;DO_1: CYCLE_ACTIVE&#10;DO_2: ALARM_LIGHT&#10;&#10;+24V_EXT: 500mA max&#10;GND_I/O: Signal ground" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=2;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;fontSize=10;" vertex="1" parent="1">
