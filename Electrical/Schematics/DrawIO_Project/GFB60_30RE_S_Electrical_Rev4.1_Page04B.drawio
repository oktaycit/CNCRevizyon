        <!-- Common Specifications -->
        <mxCell id="commspec" value="Y ve ALT EKSENİ ORTAK ÖZELLİKLERİ&#10;&#10;SERVO DRIVE (ASD-A3-2023-E):&#10;- Input: 3F 400VAC ±10%, 50/60Hz&#10;- Power: 2.0kW&#10;- Current: 6.8A (output), 7.9A (input)&#10;- Rejeneratif: 60Ω / 50W (dahili)&#10;- EtherCAT cycle: 1ms&#10;&#10;SERVO MOTOR (ECMA-E11320):&#10;- Power: 2.0kW @ 3000rpm&#10;- Voltage: 400VAC&#10;- Rated Torque: 6.37 Nm&#10;- Peak Torque: 19.1 Nm&#10;- Encoder: 24-bit absolute (16.7M counts)&#10;- Frame: 130mm&#10;- Shaft: 24mm&#10;- Weight: 11.5 kg&#10;- Protection: IP65&#10;- Cooling: Natural convection&#10;&#10;KABLOLAMA:&#10;- Power (P1): 4mm² x 4C, 5m&#10;- Motor (P2): 2.5mm² x 4C shielded, 5m&#10;- Encoder (CN2): 6x0.14mm², Hirose, 5m&#10;- I/O (CN1): 50-pin shielded, 3m&#10;- EtherCAT: CAT6 SF/UTP, 2m" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
