        </schematicView>
        <pcbView>
          <p svgId="connector0pin" layer="copper0" terminalId="connector0terminal" />
        </pcbView>
      </views>
    </connector>
    
    <connector id="connector1" name="2" type="male">
      <description>Output PNP (White)</description>
