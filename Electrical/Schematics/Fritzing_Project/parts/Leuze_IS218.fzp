  <title>Leuze IS 218 Inductive Sensor</title>
  <label>S@</label>
  <description>Leuze IS 218 Inductive Sensor with M12 4-pin connector for CNC limit/home detection</description>
  <tags>CNC, inductive sensor, Leuze, IS 218, M12 connector, limit switch, home sensor</tags>
  
  <packageInformation>
    <package name="M12-4pin" type="custom" />
  </packageInformation>
  
  <views>
    <breadboardView>
      <layers image="Leuze_IS218_breadboard.svg" layerId="breadboard" />
    </breadboardView>
    <schematicView>
      <layers image="Leuze_IS218_schematic.svg" layerId="schematic" />
    </schematicView>
    <pcbView>
      <layers image="Leuze_IS218_pcb.svg" layerId="copper0" />
    </pcbView>
  </views>
  
  <connectors>
