        <!-- 24VDC Power Distribution -->
        <mxCell id="powerdist" value="24VDC BESLEME DAĞITIMI&#10;&#10;         PSU (Page 01)&#10;         24VDC / 10A&#10;              │&#10;         ┌────┴────┐&#10;         │  X2.3   │&#10;         │ +24V    │&#10;         └────┬────┘&#10;              │&#10;    ┌─────────┼─────────┬─────────┐&#10;    │         │         │         │&#10;    ▼         ▼         ▼         ▼&#10; ┌──────┐ ┌──────┐ ┌──────┐ ┌──────┐&#10; │ F7   │ │ F8   │ │ F9   │ │ F10  │&#10; │ 2A   │ │ 2A   │ │ 2A   │ │ 2A   │&#10; └──┬───┘ └──┬───┘ └──┬───┘ └──┬───┘&#10;    │        │        │        │&#10;    │        │        │        │&#10;    ▼        ▼        ▼        ▼&#10; Valves  Contact. Light   Spare&#10; (DO_0)  (DO_1-3) (DO_4-5)&#10;&#10;Referans:&#10;• Page 01 → PSU ve ana dağıtım&#10;• Page 01 → X2 terminal bloğu&#10;• Page 02 → Safety circuit 24V&#10;&#10;Toplam Akım:&#10;• Valves: 8x 0.5A = 4A&#10;• Contactors: 4x 0.2A = 0.8A&#10;• Light: 0.875A&#10;• Buzzer: 0.1A&#10;• TOTAL: ~5.8A" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=9;fontFamily=Courier New;" vertex="1" parent="1">
